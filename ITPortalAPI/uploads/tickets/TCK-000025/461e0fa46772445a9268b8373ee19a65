<!doctype html>
<html lang="tr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>İhracat Sevkiyat Lojistik Kontrol Listesi</title>
  <style>
    :root{
      --border:#222;
      --bg:#fff;
      --muted:#666;
    }
    body{
      margin:0;
      background:#f3f3f3;
      font-family: Arial, Helvetica, sans-serif;
      color:#111;
    }
    .page{
      max-width:1100px;
      margin:24px auto;
      background:var(--bg);
      padding:18px 16px 22px;
      box-shadow:0 6px 18px rgba(0,0,0,.08);
      border:1px solid #ddd;
    }
    .title{
      text-align:center;
      font-weight:800;
      letter-spacing:.3px;
      margin:6px 0 14px;
      text-transform:uppercase;
      font-size:18px;
    }

    table{
      width:100%;
      border-collapse:collapse;
      table-layout:fixed;
      border:2px solid var(--border);
    }
    thead th{
      font-size:12px;
      text-transform:uppercase;
      font-weight:800;
      padding:10px 8px;
      border:2px solid var(--border);
      background:#fafafa;
    }
    tbody td{
      border:2px solid var(--border);
      vertical-align:top;
      padding:10px 8px;
      font-size:12px;
      line-height:1.35;
    }

    /* Sütun genişlikleri (görsele yakın) */
    .col-no{ width:52px; text-align:center; font-weight:700; }
    .col-item{ width:52%; }
    .col-done{ width:170px; text-align:center; }
    .col-note{ width:auto; }

    /* Değiştirilemez madde metni */
    .item-text{
      user-select:text;
      white-space:pre-wrap;
    }

    /* Checkbox alanı */
    .done-wrap{
      display:flex;
      flex-direction:column;
      align-items:center;
      gap:8px;
      margin-top:2px;
    }
    .done-wrap label{
      display:flex;
      align-items:center;
      gap:8px;
      cursor:pointer;
      font-weight:700;
    }
    .status{
      font-weight:800;
      padding:4px 10px;
      border:1px solid #bbb;
      border-radius:999px;
      font-size:12px;
      min-width:112px;
      text-align:center;
    }
    .status.done{ border-color:#2f7d32; color:#2f7d32; }
    .status.notdone{ border-color:#b71c1c; color:#b71c1c; }

    textarea{
      width:100%;
      min-height:62px;
      resize:vertical;
      border:1px solid #bbb;
      border-radius:6px;
      padding:8px;
      font-family:inherit;
      font-size:12px;
      box-sizing:border-box;
      outline:none;
    }
    textarea:focus{ border-color:#333; }

    .footer{
      margin-top:12px;
      border:2px solid var(--border);
      border-top:none;
      padding:10px 10px 12px;
      display:grid;
      gap:10px;
    }
    .field{
      display:flex;
      flex-wrap:wrap;
      gap:8px;
      align-items:center;
      font-size:13px;
    }
    .field b{ min-width:190px; }
    .field input{
      flex:1 1 260px;
      border:1px solid #bbb;
      border-radius:6px;
      padding:8px 10px;
      font-size:13px;
      outline:none;
    }
    .field input:focus{ border-color:#333; }

    .toolbar{
      display:flex;
      gap:10px;
      justify-content:flex-end;
      margin:10px 0 0;
      flex-wrap:wrap;
    }
    button{
      border:1px solid #222;
      background:#111;
      color:#fff;
      padding:8px 12px;
      border-radius:8px;
      cursor:pointer;
      font-weight:700;
      font-size:13px;
    }
    button.secondary{
      background:#fff;
      color:#111;
    }
    .hint{
      margin-top:8px;
      font-size:12px;
      color:var(--muted);
    }

    @media (max-width:820px){
      .col-item{ width:auto; }
      .col-done{ width:150px; }
      thead{ display:none; }
      table, tbody, tr, td{ display:block; width:100%; }
      tbody td{ border-left:2px solid var(--border); border-right:2px solid var(--border); }
      tbody tr{ border-bottom:2px solid var(--border); }
      .col-no{ text-align:left; }
    }

    @media print{
      body{ background:#fff; }
      .page{ box-shadow:none; border:none; margin:0; }
      .toolbar, .hint{ display:none !important; }
      textarea, input{ border:1px solid #000; }
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="title">İHRACAT SEVKİYAT LOJİSTİK KONTROL LİSTESİ</div>

    <table aria-label="Kontrol listesi tablosu">
      <thead>
        <tr>
          <th class="col-no">#</th>
          <th class="col-item">İhracat</th>
          <th class="col-done">Yapıldı / Yapılmadı</th>
          <th class="col-note">Açıklama</th>
        </tr>
      </thead>
      <tbody id="rows"></tbody>
    </table>

    <div class="footer">
      <div class="field">
        <b>Kontrol Eden Ad Soyad :</b>
        <input id="kontrolEden" type="text" placeholder="Örn: ERTAN SEVEN" />
      </div>
      <div class="field">
        <b>Tarih :</b>
        <input id="tarih" type="date" />
      </div>
      <div class="field">
        <b>İmza :</b>
        <input id="imza" type="text" placeholder="Örn: ERTAN SEVEN" />
      </div>

      <div class="toolbar">
        <button class="secondary" id="resetBtn" type="button">Sıfırla</button>
        <button class="secondary" id="printBtn" type="button">Yazdır</button>
      </div>
      <div class="hint">Not: Form otomatik kaydedilir (tarayıcı yerel depolama).</div>
    </div>
  </div>

  <script>
    // Değiştirilemez madde metinleri (İhracat kolonu)
    const ITEMS = [
      "KUTULARIN FİZİKİ GÖRÜNTÜSÜ DÜZGÜN MÜ?\nTAŞIMA KULAKLARINDA YIRTIK, KUTU YÜZEYİNDE YARIK-ÇİZİK, DEFORMASYON,\nŞİŞME MEVCUT MU?",
      "SİPARİŞTEKİ AYNI KALEMLERİNİN AYNI PALETLERDE OLUP OLMADIĞI KONTROL\nEDİLDİ Mİ?",
      "ÜRÜNLER TIRA YADA KONTEYNERE YÜKLENİRKEN GELİŞİ GÜZEL DEĞİL,\nMÜŞTERİ BOŞALTMA SIRASINDA MAĞDURİYET YAŞAMAYACAK ŞEKİLDE\nAYNI ÜRÜNLER VE SETLER AYNI YERE KONULDU MU?",
      "PALET BAZLI YÜKLEME LİSTESİ OLUŞTURUP SATIŞA GÖNDERİLDİ Mİ?",
      "KUTULAR YANLARDAN TAŞMAYACAK ŞEKİLDE PALETLENDİ Mİ",
      "YÜKLEMEDEN SONRA PALETLERDEN TAŞMA VAR MI?\nSEVKİYAT ESNASINDA OLUŞACAK SÜRTÜNME İLE KUTULAR\nKÖŞE VE YANLARDAN ZARAR GÖREBİLİR Mİ?",
      "STREÇLEME TAM VE ÜRÜNLERİN ALICIYA VARDIĞINDA\nKAYMAYACAK/DAĞILMAYACAK\nŞEKİLDE YAPILDI MI?",
      "DEPO'DA ATILAN PLASTİK ÇEMBER KUTUYA ZARAR VERMEYECEK ŞEKİLDE\nKUTULARDA DEFORMASYON ŞİŞME YARATIYOR MU?",
      "ÜRÜNLER TIRA YÜKLENMEDEN ÖNCE ÇEVRESEL FOTOĞRAFLAMA YAPILDI MI\nVE KAYDEDİLDİ Mİ?",
      "CHECK LİST SATIŞ İLE PAYLAŞILDI MI?"
    ];

    const LS_KEY = "ihracat_kontrol_listesi_v1";

    const $rows = document.getElementById("rows");
    const $kontrolEden = document.getElementById("kontrolEden");
    const $tarih = document.getElementById("tarih");
    const $imza = document.getElementById("imza");

    function makeRow(i, data){
      const tr = document.createElement("tr");

      // No
      const tdNo = document.createElement("td");
      tdNo.className = "col-no";
      tdNo.textContent = String(i + 1);
      tr.appendChild(tdNo);

      // Item (readonly)
      const tdItem = document.createElement("td");
      tdItem.className = "col-item";
      const div = document.createElement("div");
      div.className = "item-text";
      div.textContent = ITEMS[i]; // değiştirilemez
      tdItem.appendChild(div);
      tr.appendChild(tdItem);

      // Done checkbox -> done/notdone
      const tdDone = document.createElement("td");
      tdDone.className = "col-done";

      const wrap = document.createElement("div");
      wrap.className = "done-wrap";

      const label = document.createElement("label");
      const cb = document.createElement("input");
      cb.type = "checkbox";
      cb.checked = !!data.done;

      const spanLabel = document.createElement("span");
      spanLabel.textContent = "Yapıldı";

      label.appendChild(cb);
      label.appendChild(spanLabel);

      const status = document.createElement("div");
      status.className = "status";
      wrap.appendChild(label);
      wrap.appendChild(status);

      function syncStatus(){
        if(cb.checked){
          status.textContent = "YAPILDI";
          status.classList.add("done");
          status.classList.remove("notdone");
        }else{
          status.textContent = "YAPILMADI";
          status.classList.add("notdone");
          status.classList.remove("done");
        }
      }
      syncStatus();

      cb.addEventListener("change", () => {
        syncStatus();
        save();
      });

      tdDone.appendChild(wrap);
      tr.appendChild(tdDone);

      // Note textarea
      const tdNote = document.createElement("td");
      tdNote.className = "col-note";
      const ta = document.createElement("textarea");
      ta.placeholder = "Açıklama yazınız...";
      ta.value = data.note || "";
      ta.addEventListener("input", save);
      tdNote.appendChild(ta);
      tr.appendChild(tdNote);

      // Store refs for saving
      tr._cb = cb;
      tr._ta = ta;

      return tr;
    }

    function defaultState(){
      return {
        meta: { kontrolEden: "", tarih: "", imza: "" },
        rows: ITEMS.map(() => ({ done: false, note: "" }))
      };
    }

    function load(){
      try{
        const raw = localStorage.getItem(LS_KEY);
        if(!raw) return defaultState();
        const parsed = JSON.parse(raw);

        // Basit doğrulama
        if(!parsed || !Array.isArray(parsed.rows)) return defaultState();
        if(parsed.rows.length !== ITEMS.length) return defaultState();

        return {
          meta: parsed.meta || { kontrolEden:"", tarih:"", imza:"" },
          rows: parsed.rows.map(r => ({ done: !!r.done, note: String(r.note || "") }))
        };
      }catch{
        return defaultState();
      }
    }

    function save(){
      const state = {
        meta: {
          kontrolEden: $kontrolEden.value || "",
          tarih: $tarih.value || "",
          imza: $imza.value || ""
        },
        rows: Array.from($rows.children).map(tr => ({
          done: tr._cb.checked,
          note: tr._ta.value || ""
        }))
      };
      localStorage.setItem(LS_KEY, JSON.stringify(state));
    }

    function render(){
      const state = load();

      $kontrolEden.value = state.meta.kontrolEden || "";
      $tarih.value = state.meta.tarih || "";
      $imza.value = state.meta.imza || "";

      $rows.innerHTML = "";
      state.rows.forEach((rowData, i) => {
        $rows.appendChild(makeRow(i, rowData));
      });

      // meta input listeners
      [$kontrolEden, $tarih, $imza].forEach(el => el.addEventListener("input", save));
      [$tarih].forEach(el => el.addEventListener("change", save));
    }

    document.getElementById("printBtn").addEventListener("click", () => window.print());
    document.getElementById("resetBtn").addEventListener("click", () => {
      if(!confirm("Tüm alanlar sıfırlansın mı?")) return;
      localStorage.removeItem(LS_KEY);
      render();
    });

    render();
  </script>
</body>
</html>